---
import { Image } from 'astro:assets';
import Icon from './Icons.astro';
import { site } from '../data/site';
import logo from '../assets/logo_tortollandia_500x500.png';

// `ga` = GA4 event name fired on click (total per button, visible directly in the
// Events report). The click handler below also attaches a `zrodlo` parameter
// (strona_glowna | baner) so scans from "/" and "/banner" are countable separately.
const buttons = [
  { href: site.links.facebook, label: 'Facebook', icon: 'facebook', variant: 'plain', ext: true, aria: 'Odwiedź nasz Facebook', ga: 'click_facebook' },
  { href: site.links.instagram, label: 'Instagram', icon: 'instagram', variant: 'plain', ext: true, aria: 'Odwiedź nasz Instagram', ga: 'click_instagram' },
  { href: site.links.googleReview, label: 'Zostaw opinię', icon: 'google', variant: 'plain', ext: true, aria: 'Wystaw opinię w Google', ga: 'click_opinie' },
  { href: 'https://maps.app.goo.gl/84samJv4SSBEMwDa7?g_st=ac', label: 'Jak dojechać', icon: 'map', variant: 'plain', ext: true, aria: 'Wskazówki dojazdu w Mapach Google', ga: 'click_dojazd' },
  { href: `tel:${site.phoneE164}`, label: `Zadzwoń · ${site.phoneDisplay}`, icon: 'phone', variant: 'primary', ext: false, aria: 'Zadzwoń do Tortollandii', ga: 'click_telefon' },
  { href: '/kontakt', label: 'Kontakt · napisz do nas', icon: 'mail', variant: 'plain', ext: false, aria: 'Przejdź do formularza kontaktowego', ga: 'click_kontakt' },
];

const galleryImages = await Promise.all([
  import('../assets/gallery/1.jpg'),
  import('../assets/gallery/2.jpg'),
  import('../assets/gallery/3.jpg'),
  import('../assets/gallery/4.jpg'),
]);
---

<main class="relative z-10 mx-auto flex min-h-dvh w-full max-w-[30rem] flex-col items-center px-5 py-10">
  <header class="flex flex-col items-center text-center">
    <Image
      src={logo}
      alt="Tortollandia — Weronika Jenczelewska"
      widths={[240, 320, 480]}
      sizes="200px"
      class="w-[11.5rem] h-auto drop-shadow-[0_6px_16px_rgba(116,64,111,0.25)]"
      loading="eager"
      fetchpriority="high"
    />
    <h1 class="mt-5 text-2xl font-semibold tracking-tight text-wrzos-700">
      {site.tagline}
    </h1>
    <p class="mt-2 text-sm text-ink/70">
      Pracownia tortów artystycznych · {site.city}
    </p>
  </header>

  <nav class="mt-9 flex w-full flex-col gap-3" aria-label="Linki Tortollandia">
    {buttons.map((b) => (
      <a
        href={b.href}
        class={`hub-btn ${b.variant === 'primary' ? 'hub-btn--primary' : ''}`}
        aria-label={b.aria}
        data-ga-event={b.ga}
        data-ga-label={b.label}
        {...(b.ext ? { target: '_blank', rel: 'noopener' } : {})}
      >
        <span class="hub-icon"><Icon name={b.icon} /></span>
        <span>{b.label}</span>
        <span class="chev hub-icon" style="width:1.1rem"><Icon name="chev" /></span>
      </a>
    ))}
  </nav>

  <section class="mt-10 w-full" aria-label="Galeria tortów">
    <div class="grid grid-cols-2 gap-3">
      {galleryImages.map((img, index) => (
        <Image
          src={img.default}
          alt={`Tort artystyczny ${index + 1}`}
          class="aspect-square w-full rounded-lg object-cover"
          widths={[200, 400]}
          sizes="(max-width: 640px) 50vw, 200px"
          loading="lazy"
        />
      ))}
    </div>
  </section>

  <footer class="mt-auto pt-10 text-center text-xs text-ink/55">
    <p>© {new Date().getFullYear()} {site.name} · {site.owner}</p>
    <p class="mt-1">{site.city}, Polska</p>
  </footer>
</main>

{site.ga4Id && (
  <script is:inline>
    // GA4 click tracking for the hub buttons. Fires a named event per button
    // (visible directly in Zdarzenia) plus a `zrodlo` parameter so clicks from the
    // homepage ("/") and the banner landing ("/banner") are countable separately.
    // Bound once on `document` (which survives Astro view transitions) via a guard
    // flag; capture phase so the event is sent before navigation begins.
    (function () {
      if (window.__ttCtaBound) return;
      window.__ttCtaBound = true;
      function gtag() { (window.dataLayer = window.dataLayer || []).push(arguments); }
      document.addEventListener('click', function (e) {
        var a = e.target && e.target.closest && e.target.closest('a[data-ga-event]');
        if (!a) return;
        var zrodlo = /^\/banner(\/|$)/.test(window.location.pathname) ? 'baner' : 'strona_glowna';
        gtag('event', a.getAttribute('data-ga-event'), {
          zrodlo: zrodlo,
          link_label: a.getAttribute('data-ga-label') || (a.textContent || '').trim(),
          link_url: a.getAttribute('href'),
          page_location: window.location.href,
          transport_type: 'beacon',
        });
      }, true);
    })();
  </script>
)}
